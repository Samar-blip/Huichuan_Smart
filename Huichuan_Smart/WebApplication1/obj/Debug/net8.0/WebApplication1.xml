<?xml version="1.0"?>
<doc>
    <assembly>
        <name>WebApplication1</name>
    </assembly>
    <members>
        <member name="T:WebApplication1.Controllers.AuthController">
            <summary>
            认证控制器，提供登录、注册、改密、验证码等接口
            </summary>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.GetCaptcha">
            <summary>
            获取图形验证码（登录页调用），返回验证码ID和Base64图片
            </summary>
            <returns>包含 captchaId 和 imageBase64 的匿名对象</returns>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.Login(WebApplication1.Models.PasswordLoginRequest)">
            <summary>
            密码登录（支持用户名或手机号），需先校验图形验证码
            </summary>
            <param name="request">登录请求体，包含账号、密码、验证码ID和验证码</param>
            <returns>成功返回 accessToken、userName、realName；失败返回 401</returns>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.Register(WebApplication1.Models.RegisterRequest)">
            <summary>
            用户注册
            </summary>
            <param name="request">注册请求体，包含用户名、密码、确认密码、验证码等</param>
            <returns>成功返回提示信息；失败返回 400</returns>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.ChangePassword(WebApplication1.Models.ChangePasswordRequest)">
            <summary>
            修改密码（需登录状态）
            </summary>
            <param name="request">修改密码请求体，包含旧密码和新密码</param>
            <returns>成功返回提示信息；失败返回 400</returns>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.GetCurrentUser">
            <summary>
            获取当前登录用户信息（验证 Token 有效性）
            </summary>
            <returns>返回 userId 和 userName</returns>
        </member>
        <member name="M:WebApplication1.Controllers.AuthController.GetUserMenus">
            <summary>
            获取当前登录用户的菜单树（用于前端动态渲染左侧导航）
            </summary>
            <returns>菜单树节点列表</returns>
        </member>
        <member name="T:WebApplication1.Controllers.WeatherForecastController">
            <summary>
            天气预报接口，提供天气数据查询
            </summary>
        </member>
        <member name="M:WebApplication1.Controllers.WeatherForecastController.Get">
            <summary>
            获取未来5天的天气预报数据
            </summary>
            <returns>天气预报列表，每天包含日期、摄氏温度、华氏温度和天气摘要</returns>
        </member>
        <member name="T:WebApplication1.AsyncHttpContext">
            <summary>
            异步上下文，用于在全局拦截器中获取当前登录用户
            </summary>
        </member>
        <member name="M:WebApplication1.AsyncHttpContext.SetUserName(System.String)">
            <summary>
            从 HTTP 上下文中提取当前用户名并设置到 AsyncLocal，在中间件中调用，供 SqlSugar 拦截器使用
            </summary>
            <param name="userName">当前登录用户名</param>
        </member>
        <member name="M:WebApplication1.AsyncHttpContext.Clear">
            <summary>
            清除当前用户上下文
            </summary>
        </member>
